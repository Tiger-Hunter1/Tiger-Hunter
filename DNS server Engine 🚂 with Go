	buffer := make([]byte, 512)

	// 🚀 ৪. চব্বিশ ঘণ্টার ওত পেতে থাকার মেগা লুপ
	for {
		// ওপার থেকে আসা কাঁচা বাইনারি ডিএনএস প্যাকেট এবং ক্লায়েন্টের ঠিকানা ছেঁকে রিসিভ করা
		bytesRead, clientAddr, err := server.ReadFromUDP(buffer)
		if err != nil {
			continue
		}

		// ৫. কাঁচা বাইনারি ডাটাকে মানুষের পড়ার উপযোগী টেক্সট স্ট্রিঙে রূপান্তর করা
		rawRequest := string(buffer[:bytesRead])
		
		// উদাহরণ হিসেবে আমরা কাল্পনিক ৪টি ডোমেন ট্রাফিক টেস্ট করব
		// রিয়েল ডাটাসেটে এটি বাইনারি হেডার রিড করে ডোমেন ছেঁকে নেয়
		simulatedDomain := "pornwebsite.com" 

		currentTime := time.Now().Format("15:04:05")
		fmt.Printf("[%s] Packet Received from Client IP: %s\n", currentTime, clientAddr)

		// 🚀 ৬. কড়া এআই ফায়ারওয়াল ফিল্টারিং লজিক গেট
		if strings.Contains(simulatedDomain, "porn") || strings.Contains(simulatedDomain, "vpn") {
