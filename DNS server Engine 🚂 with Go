			fmt.Printf("  [!] ALERT: BLACKLISTED TARGET DETECTED -> [%s]\n", simulatedDomain)
			fmt.Println("  [-] ACTION: DROPPING PACKET & INJECTING BLOCKED GATEWAY IP (0.0.0.0)")
			
			// ক্লায়েন্টকে ভুয়া আইপি ফেরত পাঠিয়ে ব্লক করে দেওয়া
			server.WriteToUDP([]byte("STATUS: BLOCKED"), clientAddr)
		} else {
			// নিরাপদ সাইট হলে সবুজ সংকেত দিয়ে ডাটা পাস করা
			fmt.Printf("  [+] SUCCESS: CLEAN DOMAIN DETECTED -> [%s]\n", simulatedDomain)
			fmt.Println("  [+] ACTION: RESOLVING PATH AND TRANSMISSION ALLOWED.")
			server.WriteToUDP([]byte("STATUS: ALLOWED"), clientAddr)
		}
		fmt.Println("-----------------------------------------")
	}
}
